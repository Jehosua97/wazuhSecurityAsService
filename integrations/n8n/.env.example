# Copy this file to integrations/n8n/.env and edit the values.
# Do not commit integrations/n8n/.env.

# n8n local access
N8N_IMAGE=n8nio/n8n:1.94.1
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-in-password-manager
N8N_ENCRYPTION_KEY=change-this-32-plus-character-key
N8N_SECURE_COOKIE=false
GENERIC_TIMEZONE=America/New_York
TZ=America/New_York

# Wazuh Indexer access.
# Recommended for local testing:
# 1. Open an SSH tunnel from your laptop to the Wazuh VM.
# 2. Point n8n to https://host.docker.internal:9200
WAZUH_INDEXER_URL=https://host.docker.internal:9200
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=change-me-in-password-manager
WAZUH_INDEXER_INSECURE_TLS=true

# Vulnerability triage settings.
CLIENT_NAME=Demo PYME
VULN_MIN_SEVERITY=High
VULN_STATUS=Active
VULN_MAX_RESULTS=100
VULN_LOOKBACK_DAYS=0
VULN_TOP_FINDINGS=15

# Optional test mode. Leave empty for real Wazuh Indexer queries.
# Use /home/node/.n8n/samples/wazuh-vulnerabilities-sample.json to test without Wazuh.
TRIAGE_SAMPLE_FILE=

# Alert-to-Jira automation settings.
# Default mode only tickets alerts explicitly tagged by Wazuh rules as incident_priority_p1/p2/p3.
ALERT_WAZUH_INDEX=wazuh-alerts-*
ALERT_LOOKBACK_MINUTES=60
ALERT_MAX_RESULTS=100
ALERT_TOP_FINDINGS=25
ALERT_PRIORITIES=P1,P2,P3
ALERT_INCLUDE_LEVEL_DERIVED=false
ALERT_LEVEL_DERIVED_MIN=7
ALERT_EXCLUDE_RULE_IDS=
ALERT_SAMPLE_FILE=

# Optional asset context. Keys can be agent names or IDs.
ASSET_CRITICALITY_JSON={"wazuh.manager":"critical","db-server":"critical","edge-gateway":"high","pyme-demo-target":"high","docker-host":"high","linux-ui-workstation":"medium","metasploit-node":"low"}
ASSET_EXPOSURE_JSON={"edge-gateway":"internet","pyme-demo-target":"internal","db-server":"internal","docker-host":"internal","linux-ui-workstation":"internal","metasploit-node":"lab"}

# External enrichment sources.
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
FIRST_EPSS_URL=https://api.first.org/data/v1/epss
ENRICHMENT_OFFLINE=false

# Jira Cloud ticket creation. Keep false until credentials and project are ready.
JIRA_CREATE_TICKETS=false
JIRA_CREATE_ALERT_TICKETS=false
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=security@example.com
JIRA_API_TOKEN=change-me-in-password-manager
JIRA_PROJECT_KEY=SEC
JIRA_ISSUE_TYPE=Task
JIRA_MAX_TICKETS=15
JIRA_ALERT_MAX_TICKETS=15
JIRA_DEDUPE=true
JIRA_ALERT_DEDUPE=true
JIRA_SET_PRIORITY_FIELD=true
JIRA_DESCRIPTION_FORMAT=adf
JIRA_PRIORITY_MAP_JSON={"P1":"Highest","P2":"High","P3":"Medium","P4":"Low"}

# Reserved for the next phase. This MVP does not call AI yet.
AI_ENABLE_ANALYSIS=false
OPENAI_API_KEY=
