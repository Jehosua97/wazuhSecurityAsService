# Copy to .env or let scripts/local-docker-lab.ps1 read this value from Terraform output.
WAZUH_MANAGER_IP=REPLACE_WITH_WAZUH_PUBLIC_IP
WAZUH_VERSION=4.13.0-1

# Linux endpoint lab ports on localhost.
JUICE_SHOP_PORT=3000
DOCKER_DEMO_PORT=8081
WIREGUARD_PORT=51820
LINUX_UI_USER=analista

# Keep false for faster demos. Set true when you need the full Metasploit framework
# inside the metasploit-node container.
INSTALL_METASPLOIT=false

METASPLOIT_WORKSPACE_NAME=customer_pyme_demo
DB_NAME=customer360

# Windows containers require Docker Desktop in Windows containers mode.
WINDOWS_BASE=mcr.microsoft.com/windows/servercore:ltsc2022
