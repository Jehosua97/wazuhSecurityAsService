project_id  = "wazuh-iac-on-gcp"
region      = "us-central1"
zone        = "us-central1-a"
environment = "demo"

# For a safer demo, replace these with your public IP in CIDR form, for example:
# admin_source_ranges = ["203.0.113.10/32"]
admin_source_ranges  = ["0.0.0.0/0"]
target_source_ranges = ["0.0.0.0/0"]

# Allow additional agent sources only when needed, for example your home/office IP
# or a VPN CIDR that should be able to enroll external endpoints into the cloud manager.
# extra_agent_source_ranges = ["203.0.113.10/32"]
extra_agent_source_ranges = []

# Full cloud lab: Wazuh, Linux endpoints, Windows Server and n8n run in GCP.
# Set false only when endpoints should run locally with Docker Compose.
enable_gcp_endpoints = true

demo_company_name = "PYME Demo Mexico"
compliance_profile = "LFPDPPP, PCI-DSS v4.0, ISO 27001:2022"

wazuh_machine_type = "e2-medium"
target_instance_name = "pyme-demo-target"
target_machine_type = "e2-medium"
metasploit_instance_name = "metasploit-node"
metasploit_machine_type = "e2-standard-2"
metasploit_workspace_name = "customer_pyme_demo"
edge_gateway_instance_name = "edge-gateway"
edge_gateway_machine_type = "e2-small"
wireguard_port = 51820
db_server_instance_name = "db-server"
db_server_machine_type = "e2-medium"
db_name = "customer360"
docker_host_instance_name = "docker-host"
docker_host_machine_type = "e2-medium"
docker_demo_port = 8081
linux_ui_instance_name = "linux-ui-workstation"
linux_ui_machine_type = "e2-standard-2"
linux_ui_boot_disk_size = 50
linux_ui_user = "esquivel"
linux_ui_sensitive_dir = "/home/esquivel/Confidencial"
# Requires a GCP account/project that allows Windows Server VMs.
# If apply fails with windowsVmNotAllowedInFreeTrialProject, set this false until billing is enabled.
enable_windows_server = true
windows_instance_name = "windows-server"
windows_machine_type = "e2-standard-2"
windows_boot_disk_size = 50
windows_image = "projects/windows-cloud/global/images/family/windows-2022"
enable_n8n = true
n8n_instance_name = "n8n-automation"
n8n_machine_type = "e2-small"
n8n_boot_disk_size = 20
n8n_data_disk_size = 20
n8n_image = "n8nio/n8n:1.94.1"
n8n_port = 5678
n8n_source_ranges = ["0.0.0.0/0"]
n8n_basic_auth_user = "admin"
# Leave these empty to generate and persist them on the n8n data disk.
n8n_basic_auth_password = ""
n8n_encryption_key = ""
n8n_wazuh_indexer_username = "admin"
n8n_wazuh_indexer_password = "SecretPassword"
n8n_wazuh_indexer_insecure_tls = true
juice_shop_port = 3000
wazuh_version = "4.13.0-1"
